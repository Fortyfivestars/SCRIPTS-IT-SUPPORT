# Definir la ruta temporal y la NUEVA URL de Dropbox (ajustada a dl=1 para descarga directa)
$url = "https://www.dropbox.com/scl/fi/4pe01956xz1rmfomoqfky/DefaultRemoteOffice_Agent-2.exe?rlkey=u4d6jjdjb97b9ryyqx1ew3tbx&st=sxld7acc&dl=1"
$tempPath = "$env:TEMP\DefaultRemoteOffice_Agent_V2.exe"

Write-Host "Iniciando descarga del nuevo agente V2 (Default Remote Office)..." -ForegroundColor Cyan

# Descargar el instalador
try {
    Invoke-WebRequest -Uri $url -OutFile $tempPath -ErrorAction Stop
    Write-Host "Descarga completada." -ForegroundColor Green
} catch {
    Write-Host "Error al descargar el archivo: $($_.Exception.Message)" -ForegroundColor Red
    break
}

# Ejecutar la instalación silenciosa y esperar a que termine
Write-Host "Instalando agente V2 en modo silencioso..." -ForegroundColor Yellow
# Nota: Se utiliza /silent para la instalación desatendida de ManageEngine
Start-Process -FilePath $tempPath -ArgumentList "/silent" -Wait

# Limpiar el archivo temporal
if (Test-Path $tempPath) {
    Remove-Item $tempPath
    Write-Host "Limpieza de archivos temporales completada." -ForegroundColor Gray
}

Write-Host "Instalación del Agente V2 finalizada correctamente." -ForegroundColor Green
